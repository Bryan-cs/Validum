---
import { netStats } from "../data/content";
---

<section
  id="ecosistema"
  class="relative min-h-[90vh] overflow-hidden flex items-center"
  style="background:radial-gradient(85% 100% at 70% 50%, #152B4E 0%, #0F1825 55%, #0F1825 100%);"
>
  <canvas data-net class="absolute inset-0 z-[1] w-full h-full block"></canvas>
  <div
    class="absolute inset-0 z-[1] pointer-events-none"
    style="background:linear-gradient(90deg,#0F1825 0%, rgba(22,36,43,0.55) 34%, transparent 62%);"
  >
  </div>

  <div class="relative z-[2] max-w-[1280px] mx-auto px-6 lg:px-11 py-20 lg:py-[100px] w-full pointer-events-none">
    <div data-reveal class="max-w-[560px]">
      <h2 class="mt-[18px] mb-0 font-display font-extrabold text-[36px] lg:text-[56px] leading-[1.02] tracking-[-1.8px] text-white">
        Todos tus trámites,<br />en una <span class="italic" style="color:#C8D72B;">sola red.</span>
      </h2>
      <p class="mt-[26px] text-[17px] leading-[1.75] font-medium" style="color:#D1D5DB;">
        EPS, ARL, pensión, caja de compensación, nómina y validado por la DIAN — Validum integra cada entidad y cada
        proceso en un flujo único, seguro y trazable.
      </p>
      <div class="flex gap-[34px] mt-[42px] flex-wrap" style="pointer-events:auto;">
        {
          netStats.map((n) => (
            <div>
              <div class="font-display text-[17px] font-bold text-white">{n.k}</div>
              <div class="text-[12.5px] mt-[5px] font-medium" style="color:#E5E7EB;">{n.v}</div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
