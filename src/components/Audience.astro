---
import { publico } from "../data/content";
---

<section id="publico" class="relative max-w-[1280px] mx-auto px-6 lg:px-11 py-[90px] lg:py-[130px] bg-white">
  <div data-reveal class="max-w-[720px] mb-[56px]">
    <span class="inline-flex items-center gap-[9px] font-body text-[12.5px] font-bold tracking-[1.5px]" style="color:#1D3F72;">
      PÚBLICO OBJETIVO
    </span>
    <h2 class="mt-[18px] mb-0 font-display font-extrabold text-[34px] lg:text-[54px] leading-[1.05] tracking-[-1.8px] text-ink">
      Diseñado para quien quiere <span class="italic" style="color:#C8D72B;">crecer</span> sin fricción
    </h2>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-[26px]">
    {
      publico.map((p) => (
        <div
          data-reveal
          class="pcard rounded-3xl overflow-hidden bg-white border-[1.5px]"
          style="border-color:#E5E7EB; box-shadow:0 18px 44px -34px rgba(27,42,49,0.3);"
        >
          <div class="relative h-[280px] overflow-hidden">
            <img src={p.img} alt={p.alt} width="700" height="560" loading="lazy" decoding="async" class="pimg w-full h-full object-cover block" />
            <div class="pimg-overlay absolute inset-0 flex items-end p-5" style="background:linear-gradient(to top,rgba(17,19,23,0.82) 0%,transparent 60%); opacity:0; transition:opacity 0.35s;">
              <span class="font-display text-[12px] font-bold text-white tracking-[1.5px] uppercase">{p.tag}</span>
            </div>
          </div>
          <div class="p-[30px]">
            <div class="font-display text-[22px] font-bold text-ink">{p.title}</div>
            <div class="text-[14.5px] mt-3 leading-[1.7] font-medium" style="color:#1A1C22;">{p.desc}</div>
          </div>
        </div>
      ))
    }
  </div>
</section>
