---
import { contactInfo, formFields } from "../data/content";

const autocompleteFor: Record<string, string> = {
  text: "organization",
  email: "email",
  tel: "tel",
};

const contactIcons: Record<string, string> = {
  Correo: '<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>',
  Cobertura: '<circle cx="12" cy="10" r="3"/><path d="M12 2a8 8 0 0 0-8 8c0 5.4 7.05 11.5 7.35 11.76a1 1 0 0 0 1.3 0C13 21.5 20 15.4 20 10a8 8 0 0 0-8-8z"/>',
  Horario: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
};
---

<section id="contacto" class="relative overflow-hidden" style="background:#111317;">

  <!-- bg glow left -->
  <div class="absolute left-[-120px] top-[-80px] w-[600px] h-[600px] rounded-full pointer-events-none"
    style="background:radial-gradient(circle, rgba(29,63,114,0.35) 0%, transparent 70%); filter:blur(0px);">
  </div>

  <!-- bg glow gold bottom-right -->
  <div class="absolute right-[-60px] bottom-[-60px] w-[400px] h-[400px] rounded-full pointer-events-none"
    style="background:radial-gradient(circle, rgba(200,215,43,0.09) 0%, transparent 70%);">
  </div>

  <!-- V monogram watermark -->
  <div class="absolute right-[-30px] top-1/2 -translate-y-1/2 z-0 font-display font-extrabold leading-[0.7] select-none pointer-events-none"
    style="font-size:520px; opacity:0.04; color:#fff;">
    V
  </div>

  <!-- gold top strip -->
  <div class="absolute top-0 left-0 right-0 h-[3px]"
    style="background:linear-gradient(90deg, transparent 0%, #C8D72B 30%, #C8D72B 70%, transparent 100%);">
  </div>

  <div class="relative z-[2] max-w-[1280px] mx-auto px-6 lg:px-11 pt-[90px] lg:pt-[120px] pb-[50px]">
    <div class="two-col grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-12 lg:gap-[74px] items-center">

      <!-- copy -->
      <div data-reveal>

        <!-- gold badge -->
        <div class="inline-flex items-center gap-[10px] mb-[28px] py-[7px] px-[14px] rounded-full"
          style="background:rgba(200,215,43,0.1); border:1px solid rgba(200,215,43,0.25);">
          <span class="w-[6px] h-[6px] rounded-full" style="background:#C8D72B; box-shadow:0 0 8px #C8D72B;"></span>
          <span class="font-body text-[11.5px] font-bold tracking-[1.5px]" style="color:#C8D72B;">HABLEMOS</span>
        </div>

        <h2 class="mt-0 mb-0 font-display font-extrabold text-[40px] lg:text-[62px] leading-[1.0] tracking-[-2px] text-white">
          Delega hoy.<br />
          <span class="italic" style="color:#C8D72B;">Crece</span> mañana.
        </h2>

        <p class="mt-[26px] text-[17px] leading-[1.7] font-medium max-w-[440px]" style="color:rgba(255,255,255,0.7);">
          Cuéntanos sobre tu empresa y diseñamos un esquema de outsourcing a tu medida. Sin compromiso.
        </p>

        <!-- divider -->
        <div class="mt-[42px] mb-[38px] h-[1px]" style="background:linear-gradient(90deg,rgba(200,215,43,0.4),transparent);"></div>

        <!-- contact items -->
        <div class="flex flex-col gap-[22px]">
          {
            contactInfo.map((c) => (
              <div class="flex items-center gap-[16px]">
                <div class="w-[40px] h-[40px] rounded-[11px] grid place-items-center flex-shrink-0"
                  style="background:rgba(29,63,114,0.4); border:1px solid rgba(29,63,114,0.6);">
                  <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#B8CCE4" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"
                    set:html={contactIcons[c.k] ?? ''} />
                </div>
                <div>
                  <div class="text-[10px] tracking-[1.5px] uppercase font-bold" style="color:rgba(255,255,255,0.4);">{c.k}</div>
                  <div class="font-display text-[15px] font-bold text-white mt-[2px]">{c.v}</div>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- form -->
      <form
        data-reveal
        data-contact-form
        class="relative p-[38px] rounded-[24px]"
        style="background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.08); box-shadow:0 0 0 1px rgba(200,215,43,0.08) inset, 0 40px 80px -40px rgba(0,0,0,0.6);"
      >
        <!-- form gold top accent -->
        <div class="absolute top-0 left-[10%] right-[10%] h-[2px] rounded-full"
          style="background:linear-gradient(90deg,transparent,rgba(200,215,43,0.6),transparent);">
        </div>

        {
          formFields.map((f, i) => {
            const id = `cf-${i}`;
            return (
              <div class="fl-wrap mb-[16px]">
                <input
                  id={id}
                  name={id}
                  type={f.type}
                  required
                  autocomplete={autocompleteFor[f.type] ?? "on"}
                  placeholder=" "
                  class="fl-input w-full rounded-[13px] bg-white/[0.05] border border-white/[0.10] text-white font-body text-[14.5px] outline-none focus:border-blue"
                  style="transition:border-color 0.2s, background 0.2s;"
                />
                <label for={id} class="fl-label">
                  {f.label} <span style="color:#B8CCE4;">*</span>
                </label>
              </div>
            );
          })
        }
        <div class="fl-wrap fl-wrap--area mb-[20px]">
          <textarea
            id="cf-msg"
            name="cf-msg"
            rows="3"
            placeholder=" "
            class="fl-input fl-input--area w-full rounded-[13px] bg-white/[0.05] border border-white/[0.10] text-white font-body text-[14.5px] outline-none resize-none focus:border-blue"
            style="transition:border-color 0.2s, background 0.2s;"
          ></textarea>
          <label for="cf-msg" class="fl-label fl-label--area">Mensaje</label>
        </div>

        <button
          type="submit"
          class="btn-blue w-full inline-flex items-center justify-center gap-3 cursor-pointer py-[17px] rounded-[13px] font-body font-bold text-[15.5px] text-white border-none"
          style="background:#25D366; box-shadow:0 14px 36px -12px rgba(37,211,102,0.45);"
        >
          <svg width="22" height="22" viewBox="0 0 24 24" fill="white" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Escribir por WhatsApp
        </button>
        <p
          data-form-status
          role="status"
          aria-live="polite"
          class="text-[13px] text-center mt-3 font-medium hidden"
          style="color:#B8CCE4;"
        >
        </p>
      </form>
    </div>

    <!-- footer -->
    <div class="flex items-center justify-between mt-[90px] pt-[34px] border-t flex-wrap gap-5" style="border-color:rgba(255,255,255,0.07);">
      <div class="flex items-center gap-[13px]">
        <img src="/logo-validum.png" alt="Validum" class="h-[38px] w-auto object-contain block" style="filter:brightness(0) invert(1);" />
        <div class="font-display font-bold text-[16px] text-white">
          Validum <span class="font-medium text-[13px]" style="color:rgba(255,255,255,0.75);">· Grupo Empresarial S.A.S.</span>
        </div>
      </div>
      <div class="text-[13px] font-medium" style="color:rgba(255,255,255,0.65);">
        © 2026 Grupo Empresarial Validum S.A.S. — Outsourcing administrativo en Colombia.
      </div>
    </div>
  </div>
</section>
