---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Outsourcing de nómina y seguridad social en Colombia | Validum",
  description = "Outsourcing administrativo en Colombia: afiliaciones a EPS, ARL, pensión y caja, administración de nómina electrónica, novedades laborales y facturación electrónica DIAN. Cumplimiento garantizado.",
} = Astro.props;

const siteOrigin = "https://validum.com.co";
const ogImage = `${siteOrigin}/og-image.jpg`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#F8F7F4" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta
      name="keywords"
      content="outsourcing administrativo, outsourcing de nómina, seguridad social Colombia, afiliaciones EPS ARL pensión caja, facturación electrónica DIAN, nómina electrónica, novedades laborales"
    />
    <meta name="geo.region" content="CO" />
    <meta name="geo.placename" content="Colombia" />

    <!-- LCP preload: imagen local, sin CDN externo -->
    <link rel="preload" as="image" href="/hero.jpg" fetchpriority="high" />

    <link rel="canonical" href={`${siteOrigin}/`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${siteOrigin}/`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_CO" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured data -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "ProfessionalService",
        "@id": `${siteOrigin}/#organization`,
        name: "Grupo Empresarial Validum S.A.S.",
        alternateName: "Validum",
        url: siteOrigin,
        image: ogImage,
        description,
        priceRange: "$$",
        areaServed: {
          "@type": "Country",
          name: "Colombia",
        },
        email: "contacto@validum.com.co",
        telephone: "+573185301171",
        address: {
          "@type": "PostalAddress",
          addressCountry: "CO",
          addressRegion: "Colombia",
        },
        contactPoint: {
          "@type": "ContactPoint",
          telephone: "+573185301171",
          contactType: "customer service",
          availableLanguage: "Spanish",
          areaServed: "CO",
        },
        openingHoursSpecification: {
          "@type": "OpeningHoursSpecification",
          dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
          opens: "08:00",
          closes: "18:00",
        },
        knowsAbout: [
          "Seguridad social",
          "Nómina electrónica",
          "Facturación electrónica DIAN",
          "Outsourcing administrativo",
          "Afiliaciones EPS",
          "Afiliaciones ARL",
          "Administración de nómina Colombia",
        ],
        hasOfferCatalog: {
          "@type": "OfferCatalog",
          name: "Servicios de outsourcing administrativo",
          itemListElement: [
            "Afiliaciones a seguridad social (EPS, ARL, pensión y caja de compensación)",
            "Radicación de novedades laborales",
            "Administración de nómina",
            "Implementación de facturación electrónica DIAN",
            "Gestión de documentos electrónicos",
          ].map((s) => ({
            "@type": "Offer",
            itemOffered: { "@type": "Service", name: s },
          })),
        },
        sameAs: [],
      })}
    />
  </head>
  <body>
    <a
      href="#contenido"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-[300] focus:px-4 focus:py-2 focus:rounded-lg focus:bg-blue focus:text-ink focus:font-bold focus:no-underline"
    >
      Saltar al contenido
    </a>
    <div class="grain"></div>
    <slot />
  </body>
</html>
